{{- $machine_types := list "personal" "work" -}}
{{- $machine_type := promptChoiceOnce . "machine_type" "What type of machine are you on" $machine_types -}}
{{ $personal_email := promptStringOnce . "personal_email" "What is your personal email address" }}
data:
  machine_type: {{ $machine_type }}
  personal_email: {{ $personal_email }}
{{ if eq $machine_type "work" }}
  {{ $work_email := promptStringOnce . "work_email" "What is your work email address" }}
  {{ $work_tld := promptStringOnce . "work_tld" "What is your work TLD?" }}
  work_email: {{ $work_email }}
  work_tld: {{ $work_tld }}
{{ end }}
